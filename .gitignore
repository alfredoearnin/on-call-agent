# Dependencies
/node_modules
/.pnp
.pnp.*

# Next.js
/.next/
/out/
next-env.d.ts

# Production
/build

# Debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Secrets and local env — NEVER commit real env files (fintech rule).
# Only .env.example (placeholders) is tracked.
.env
.env.local
.env.*.local
.env.development
.env.production

# OS
.DS_Store
*.pem

# TypeScript
*.tsbuildinfo

# Prisma
# NOTE: the SQLite "memory" DB (prisma/oncall.db) is intentionally COMMITTED
# so a fresh clone inherits the shared incident/recommendation history.
# Ignore only the transient SQLite sidecar files.
prisma/oncall.db-journal
prisma/oncall.db-wal
prisma/oncall.db-shm

# Scheduler runtime lock
.sync.lock
