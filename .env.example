# =============================================================================
# On-call Ops Dashboard — environment template
# Copy to .env.local (secrets) and .env (DATABASE_URL for the Prisma CLI).
# `bash scripts/install.sh` does this for you. NEVER commit real values.
# =============================================================================

# --- Database (non-secret) ---------------------------------------------------
# SQLite committed "memory" DB. Path is resolved relative to prisma/schema.prisma.
DATABASE_URL="file:./oncall.db"

# --- Demo mode ---------------------------------------------------------------
# When true (default), ingestion uses bundled sample data so the dashboard works
# with zero credentials. Set to false once real API keys are configured below.
DEMO_MODE="true"

# --- Team / analysis config (mirrors on-call.md) -----------------------------
TEAM_TAG="team:l2-peng-growth"
TEAM_LABEL="Growth Team"
TIMEZONE="America/Los_Angeles"

# --- Datadog (read) ----------------------------------------------------------
# Site matches app.datadoghq.com (US1). Change for EU/US3/US5 etc.
DD_SITE="datadoghq.com"
DD_API_KEY=""
DD_APP_KEY=""

# --- Datadog (write) — ONLY used by the guarded "Apply suggestion" feature ----
# Keep separate from the read key (least privilege). Leave APPLY_ENABLED=false
# unless you intend to let the dashboard edit real monitors.
APPLY_ENABLED="false"
DD_APP_KEY_WRITE=""

# --- incident.io (read) ------------------------------------------------------
INCIDENT_IO_API_KEY=""

# --- Jira (read, optional — vulnerabilities) ---------------------------------
JIRA_BASE_URL="https://earnin.atlassian.net"
JIRA_EMAIL=""
JIRA_API_TOKEN=""
JIRA_VULN_FILTER_ID="15295"

# --- Sync API guard (for a future scheduler / Vercel Cron) -------------------
CRON_SECRET=""

# --- Operator label recorded in the apply audit trail ------------------------
OPERATOR_NAME="local-operator"
